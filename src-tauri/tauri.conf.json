{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "TokenBurger",
    "version": "0.1.2",
    "identifier": "com.tokenburger.desktop",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://127.0.0.1:1420",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "security": {
            "csp": null
        },
        "macOSPrivateApi": true,
        "windows": [
            {
                "label": "settings",
                "title": "TokenBurger Settings",
                "url": "index.html#/settings",
                "width": 600,
                "height": 400,
                "resizable": true,
                "decorations": true,
                "visible": false
            }
        ],
        "trayIcon": null
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "macOS": {
            "signingIdentity": "-"
        },
        "resources": [
            "resources/*"
        ],
        "icon": [
            "icons/app-32x32.png",
            "icons/app-128x128.png",
            "icons/app-128x128@2x.png",
            "icons/app-icon.icns",
            "icons/app-icon.ico"
        ]
    }
}
