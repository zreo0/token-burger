{
    "name": "token-burger",
    "private": true,
    "version": "0.2.15",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:run": "vitest --run",
        "fmt:rust": "cd src-tauri && cargo fmt --check",
        "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
        "test:rust": "cd src-tauri && cargo test",
        "check:ci": "npm run lint && npm run typecheck && npm run test:run && npm run fmt:rust && npm run lint:rust && npm run test:rust"
    },
    "dependencies": {
        "@tauri-apps/api": "^2.0.0",
        "@tauri-apps/plugin-opener": "^2.5.3",
        "@tauri-apps/plugin-updater": "^2.10.1",
        "framer-motion": "^11.0.0",
        "i18next": "^24.0.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "react-i18next": "^15.0.0",
        "react-router-dom": "^7.0.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@tauri-apps/cli": "^2.0.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitejs/plugin-react": "^4.0.0",
        "eslint": "^9.0.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.6.0",
        "vite": "^6.0.0",
        "vitest": "^3.0.0"
    }
}
